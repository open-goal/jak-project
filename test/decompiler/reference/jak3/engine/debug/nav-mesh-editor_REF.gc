            (bucket-id debug-no-zbuf1)
            (-> s3-1 data (-> s1-1 indices 0))
            (-> s3-1 data (-> s1-1 indices 2))
            (-> s3-1 data (-> s1-1 indices 3))
            (new 'static 'rgba :r #x80 :g #x40 :b #x80 :a #x20)
            )
