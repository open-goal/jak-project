  (format #t "~2Tmouse-tumble-dist: ~f~%" (-> this mouse-tumble-dist))
  (format #t "~2Tmouse-tumble: #<vector @ #x~X>~%" (-> this mouse-tumble))
  (format #t "~2Tmanipulator-pos: #<vector @ #x~X>~%" (-> this manipulator-pos))
