         (a1-6 (-> this nav-graph node-array data (-> gp-0 runtime-node-id-1)))
         (s2-0 (-> this nav-graph node-array data (-> gp-0 runtime-node-id-2)))
         (s3-0 (new 'stack-no-clear 'vector))
         (s5-0 (new 'stack-no-clear 'vector))
         (s4-0 (new 'stack-no-clear 'vector))
         )
    (get-node-draw-position s5-0 a1-6)
    (get-node-draw-position s4-0 s2-0)
    (vector-! s3-0 s5-0 s4-0)
    (set! (-> s3-0 y) 0.0)
    (vector-rotate90-around-y! s3-0 s3-0)
    (vector-normalize! s3-0 (-> gp-0 width))
    (add-debug-line
      #t
      (bucket-id debug)
      (vector+! (new 'stack-no-clear 'vector) s5-0 s3-0)
      (vector+! (new 'stack-no-clear 'vector) s4-0 s3-0)
      *color-red*
      #f
      (the-as rgba -1)
