        (new 'stack-no-clear 'vector)
        (-> this nav-graph node-array data (-> s3-0 runtime-node-id-1))
        )
      (get-node-draw-position
        (new 'stack-no-clear 'vector)
        (-> this nav-graph node-array data (-> s3-0 runtime-node-id-2))
        )
      )
    (dotimes (s3-1 (-> this nav-graph visnode-array length))
