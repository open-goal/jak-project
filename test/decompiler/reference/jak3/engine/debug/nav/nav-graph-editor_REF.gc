    (get-node-draw-position s5-0 gp-0)
    (cond
      ((= (-> this nav-graph nav_graph_id) 4)
       (add-debug-sphere #t (bucket-id debug) s5-0 (-> gp-0 radius) *color-green*)
       )
      (else
        (new 'stack-no-clear 'vector)
        (let ((s4-1 (new 'stack-no-clear 'vector)))
          (sincos! s4-1 (-> gp-0 angle))
          (set! (-> s4-1 z) (-> s4-1 y))
          (set! (-> s4-1 y) 0.0)
          (set! (-> s4-1 w) 1.0)
          (add-debug-sphere
            #t
            (bucket-id debug)
            (vector+*! (new 'stack-no-clear 'vector) s5-0 s4-1 (-> gp-0 radius))
            (-> gp-0 radius)
            *color-green*
            )
          (add-debug-sphere
            #t
            (bucket-id debug)
            (vector+*! (new 'stack-no-clear 'vector) s5-0 s4-1 (- (-> gp-0 radius)))
            (-> gp-0 radius)
