;; definition for method 3 of type nav-graph-editor
(defmethod inspect ((this nav-graph-editor))
  (when (not this)
    (set! this this)
    (goto cfg-4)
    )
  (let ((t9-0 (method-of-type process inspect)))
    (t9-0 this)
