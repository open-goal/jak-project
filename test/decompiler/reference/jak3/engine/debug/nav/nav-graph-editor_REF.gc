  (format #t "~2Tmouse-spos-hold: #<vector @ #x~X>~%" (-> this mouse-spos-hold))
  (format #t "~2Tedge-src: ~D~%" (-> this edge-src))
  (format #t "~2Tedge-dst: ~D~%" (-> this edge-dst))
  (format #t "~2Tedge-visibility: ~D~%" (-> this edge-visibility))
  (format #t "~2Tvehicle-edit-mode: ~A~%" (-> this vehicle-edit-mode))
  (format #t "~2Thover-edit-mode: ~A~%" (-> this hover-edit-mode))
