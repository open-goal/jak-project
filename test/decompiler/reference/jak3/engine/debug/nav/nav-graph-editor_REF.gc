      (if (= (logand s2-0 (nav-minimap-edge-flag blocker)) (nav-minimap-edge-flag blocker))
          (format *stdcon* "blocker ")
          )
      (if (= (logand s2-0 (nav-minimap-edge-flag pass-indb-sluma)) (nav-minimap-edge-flag pass-indb-sluma))
