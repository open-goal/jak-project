;; definition for method 15 of type mysql-nav-graph
(defmethod indexof-visnode ((this mysql-nav-graph) (arg0 int) (arg1 int))
  (dotimes (v1-0 (-> this visnode-array length))
    (let ((a3-2 (-> this visnode-array data v1-0)))
      (if (and (= (-> a3-2 runtime-edge-id) arg0) (= (-> a3-2 runtime-node-id) arg1))
          (return v1-0)
          )
      )
    )
  -1
  )

;; definition for method 16 of type mysql-nav-graph
(defmethod alloc-new-visnode! ((this mysql-nav-graph) (arg0 int) (arg1 int))
  (cond
    ((>= (-> this visnode-array length) 3000)
