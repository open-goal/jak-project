          (return v1-3)
          )
        )
      (let ((v1-9 (-> this visnode-array data (-> this visnode-array length)))
            (v0-1 (-> this visnode-array length))
            )
        (+! (-> this visnode-array length) 1)
        (set! (-> v1-9 mysql-save-flag) (mysql-save-flag))
        (logior! (-> v1-9 mysql-save-flag) (mysql-save-flag insert))
        (set! (-> v1-9 runtime-edge-id) arg0)
        (set! (-> v1-9 runtime-node-id) arg1)
        (set! (-> v1-9 nav_graph_id) (-> this nav_graph_id))
