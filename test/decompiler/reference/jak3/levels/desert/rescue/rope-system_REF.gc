  (the-as rope-system (when (nonzero? (-> this knot-constraints))
                        (let ((v0-0 (&+ (-> this knot-constraints) offset)))
                          (set! (-> this knot-constraints) v0-0)
                          v0-0
                          )
                        )
          )
  )

