  (set! (-> this knot-constraints) (new 'process 'rope-knot-constraint-array (+ arg0 -1)))
  (set! (-> this knots length) (-> this knots allocated-length))
  (set! (-> this knot-constraints length) (-> this knot-constraints allocated-length))
