                (new 'static 'vector :y 4096.0 :w 1.0)
                (new 'static 'vector :y 4096.0 :w 1.0)
                (new 'static 'vector :z 40960.0 :w 1.0)
                (new 'static 'vector :x 4096.0 :w 1.0)
                (new 'static 'vector :z 40960.0 :w 1.0)
                (new 'static 'vector :y -4096.0 :w 1.0)
                (new 'static 'vector :z 40960.0 :w 1.0)
                (new 'static 'vector :x -4096.0 :w 1.0)
                (new 'static 'vector :z 40960.0 :w 1.0)
                )
              )
