(defun-debug draw-debug-sphere ((arg0 vector) (arg1 bucket-id) (arg2 float) (arg3 rgba))
  (add-debug-sphere
    #t
    arg1
    arg0
    (if (< 0.0 arg2)
        arg2
        (-> arg0 w)
        )
    arg3
    )
  0
  (none)
  )

