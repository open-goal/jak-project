  (format #t "~1Tanim-part: ~D~%" (-> this anim-part))
  (format #t "~1Tflags: ~D~%" (-> this flags))
  (format #t "~1Tname: ~A~%" (-> this name))
  (format #t "~1Tid: ~D~%" (-> this id))
