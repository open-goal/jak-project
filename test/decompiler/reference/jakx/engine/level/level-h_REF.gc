  )

;; definition for method 3 of type level
(defmethod inspect ((this level))
  (when (not this)
    (set! this this)
    (goto cfg-48)
    )
  (format #t "[~8x] ~A~%" this (-> this type))
  (format #t "~1Tname: ~A~%" (-> this name))
  (format #t "~1Tload-name: ~A~%" (-> this load-name))
  (format #t "~1Tnickname: ~A~%" (-> this nickname))
