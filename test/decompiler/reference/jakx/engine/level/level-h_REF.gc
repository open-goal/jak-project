  (format #t "~1Tstatus: ~A~%" (-> this status))
  (format #t "~1Tborrow-level[3] @ #x~X~%" (-> this borrow-level))
  (dotimes (s5-0 3)
    (format #t "~T  [~D]~1Tborrow-level: ~A~%" s5-0 (-> this borrow-level s5-0))
    )
  (format #t "~1Tborrow-from-level: ~A~%" (-> this borrow-from-level))
