            (set! t9-0 (method-of-type v1-0 new))
            (set! v1-1 a1-0)
            (set! a1-1 (-> a1-0 size))
            (set! a2-1 (sll a2-0 5))
            (set! a2-2 (+ a1-1 a2-1))
            (set! a1-2 v1-1)
            (set! v0-0 (call! a0-0 a1-2 a2-2))
            (set! s5-0 v0-0)
            (zero? s5-0)
