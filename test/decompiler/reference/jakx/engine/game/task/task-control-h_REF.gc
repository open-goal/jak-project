;; definition of type game-task-event
(deftype game-task-event (basic)
  ((actor     game-task-actor)
   (action    game-task-action)
   (tex       game-task-icon)
   (icon      uint16           :overlay-at tex)
   (flags     game-task-flags  :offset   7)
   (scene     string           :offset   8)
   (distance  meters)
   )
  )

;; definition for method 3 of type game-task-event
(defmethod inspect ((this game-task-event))
  (when (not this)
    (set! this this)
    (goto cfg-4)
    )
  (format #t "[~8x] ~A~%" this (-> this type))
  (format #t "~1Tactor: #x~X : ~S~%" (-> this actor) (game-task-actor->string (-> this actor)))
  (format #t "~1Taction: #x~X : ~S~%" (-> this action) (game-task-action->string (-> this action)))
  (format #t "~1Tflags: ~D~%" (-> this flags))
  (format #t "~1Ticon: ~D~%" (-> this icon))
  (format #t "~1Tskull-cost: ~D~%" (-> this tex))
  (format #t "~1Tscene: ~A~%" (-> this scene))
  (format #t "~1Tdistance: (meters ~m)~%" (-> this distance))
  (label cfg-4)
  this
  )

