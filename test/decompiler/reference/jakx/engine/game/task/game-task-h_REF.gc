;; definition of type task-level-info
(deftype task-level-info (structure)
  ((flags                uint32)
   (text-id              uint32)
   (venue-text-id        uint32)
   (caps-text-id         uint32)
   (tex-name             basic)
   (race-mesh-name       basic)
   (race-banner-name     basic)
   (race-ai-tuning-name  basic)
   )
  )

;; definition for method 3 of type task-level-info
(defmethod inspect ((this task-level-info))
  (when (not this)
    (set! this this)
    (goto cfg-4)
    )
  (format #t "[~8x] ~A~%" this 'task-level-info)
  (format #t "~1Tflags: ~D~%" (-> this flags))
  (format #t "~1Ttext-id: ~D~%" (-> this text-id))
  (format #t "~1Tvenue-text-id: ~D~%" (-> this venue-text-id))
  (format #t "~1Tcaps-text-id: ~D~%" (-> this caps-text-id))
  (format #t "~1Ttex-name: ~A~%" (-> this tex-name))
  (format #t "~1Trace-mesh-name: ~A~%" (-> this race-mesh-name))
  (format #t "~1Trace-banner-name: ~A~%" (-> this race-banner-name))
  (format #t "~1Trace-ai-tuning-name: ~A~%" (-> this race-ai-tuning-name))
  (label cfg-4)
  this
  )

