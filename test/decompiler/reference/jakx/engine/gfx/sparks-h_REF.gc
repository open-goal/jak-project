  )

;; definition of type spark-line-packet
(deftype spark-line-packet (structure)
  ((tag    qword       :inline)
   (alpha  qword       :inline)
   (verts  spark-vert  4 :inline)
   )
  )

;; definition for method 3 of type spark-line-packet
(defmethod inspect ((this spark-line-packet))
