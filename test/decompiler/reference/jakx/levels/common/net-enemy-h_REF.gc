(defmethod process-nettable-method-37 ((this net-enemy) (arg0 net-process-class-info))
  (set! (-> arg0 msg-map (-> arg0 msg-count)) 'transition)
  (+! (-> arg0 msg-count) 1)
  (set! (-> arg0 msg-map (-> arg0 msg-count)) 'damage)
  (+! (-> arg0 msg-count) 1)
  0
  (none)
  )

