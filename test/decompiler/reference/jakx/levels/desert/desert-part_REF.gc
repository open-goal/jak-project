;; definition for function birth-func-desert-beacon-set-accel
;; INFO: Used lq/sq
;; WARN: Return type mismatch vector vs none.
(defun birth-func-desert-beacon-set-accel ((arg0 sparticle-system) (arg1 sparticle-cpuinfo) (arg2 sparticle-launchinfo))
  (let ((s5-0 (new 'stack-no-clear 'vector)))
    (set! (-> s5-0 quad) (-> (math-camera-matrix) rvec quad))
    (set! (-> s5-0 y) 0.0)
    (vector-normalize! s5-0 6.826667)
    (set! (-> s5-0 y) (-> arg1 acc y))
    (set! (-> arg1 acc x) (-> s5-0 x))
    (set! (-> arg1 acc y) (-> s5-0 y))
    (set! (-> arg1 acc z) (-> s5-0 z))
    )
  (-> arg1 acc)
  (none)
  )

