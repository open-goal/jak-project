              (let ((planes (the-as object (make-property-data amb 0.0 (the-as res-tag-pair vol-idx) (the-as pointer #f)))))
                (set! in-vol? #t)
                (countdown (i (-> vol elt-count))
                  (when (< (-> pos w)
                           (- (vector-dot pos (-> (the-as (inline-array vector) planes) i)) (-> (the-as (inline-array vector) planes) i w)))
