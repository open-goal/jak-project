              (let ((elts (the-as object (make-property-data amb 0.0 (the-as res-tag-pair vol-idx) (the-as pointer #f)))))
                (set! in-vol? #t)
                (countdown (a0-6 (-> vol elt-count))
                  (when (< (-> pos w)
                           (- (vector-dot pos (-> (the-as (inline-array vector) elts) a0-6)) (-> (the-as (inline-array vector) elts) a0-6 w)))
                    (set! in-vol? #f)
                    (goto cfg-9))))
              (label cfg-9)
              (if in-vol? (goto cfg-15))
              (+! vol-idx 1)
              (set! vol (-> amb tag vol-idx))))))
      (label cfg-15)
      (when in-vol?)))
  0
  (none))

