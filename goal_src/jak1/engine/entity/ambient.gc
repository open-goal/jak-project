          (in-vol? #t))
      (let ((first-vol-idx (-> ((method-of-type res-lump lookup-tag-idx) amb 'vol 'exact 0.0) lo)))
        (when (>= (the-as int first-vol-idx) 0)
          (let ((vol-idx (the-as int first-vol-idx))
                (vol (-> amb tag first-vol-idx)))
