(defun type-from-driver-type ((arg0 driver-type))
  (case arg0
    (((driver-type d-jak))
     driver-jak
     )
    (((driver-type d-ashelin))
     driver-ashelin
     )
    (((driver-type d-razer))
     driver-razer
     )
    (((driver-type d-klever))
     driver-klever
     )
    (((driver-type d-kiera))
     driver-kiera
     )
    (((driver-type d-thug-a))
