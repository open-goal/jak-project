;;-*-Lisp-*-
(in-package goal)

;; name: penetrate-h.gc
;; name in dgo: penetrate-h
;; dgos: ENGINE, GAME

;; +++knocked-type
(defenum knocked-type
  :type uint8
  (none 0)
  (mech-punch 1)
  (explode-or-darkjak 2)
  (dark-shot 3)
  (yellow-shot 4)
  (red-shot 5)
  (blue-shot 6)
  (vehicle 7)
  (knocked-off 8)
  )
;; ---knocked-type

;; +++penetrate
