;;-*-Lisp-*-
(in-package goal)

;; name: bsp-h.gc
;; name in dgo: bsp-h
;; dgos: ENGINE, GAME

;; DECOMP BEGINS

(deftype collide-stats (structure)
  "Very strange collide stats type. It has been somewhat broken in all versions of the game.
The final stopwatch is cut off. For jak 3, I just fixed it."
  ((calls    uint32)
   (spheres  uint32)
   (nodes    uint32)
   (frags    uint32)
   (tris     uint32)
   (output   uint32)
   (junk     (pointer uint32)  24)
   )
  )
