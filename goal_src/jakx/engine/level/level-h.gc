              )
            (new 'static 'level
              :name #f
              :index 8
              :status 'inactive
              :inside-boxes? #f
              :force-inside? #f
              :linking #f
              :level-type #f
              )
            (new 'static 'level
              :name #f
              :index 9
              :status 'inactive
              :inside-boxes? #f
              :force-inside? #f
              :linking #f
              :level-type #f
              )
            (new 'static 'level
              :name #f
              :index 10
              :status 'inactive
              :inside-boxes? #f
              :force-inside? #f
              :linking #f
              :level-type #f
              )
            (new 'static 'level
              :name #f
              :index 11
              :status 'inactive
              :inside-boxes? #f
              :force-inside? #f
              :linking #f
              :level-type #f
              )
            (new 'static 'level
              :name #f
              :index 12
              :status 'inactive
