;;-*-Lisp-*-
(in-package goal)

;; name: water-info-h.gc
;; name in dgo: water-info-h
;; dgos: ENGINE, GAME

;; DECOMP BEGINS

(deftype water-info (structure)
  ((trans        vector  :inline)
   (normal       vector  :inline)
   (base-height  meters)
   (depth        meters)
   (handle       handle)
   (flags        water-flag)
   (prim         drawable-region-prim)
   (extra-flags  uint32)
   )
  )


(deftype water-sphere (structure)
  ((sphere  sphere  :inline)
   (flags   water-flag)
   (user0   int32)
   )
  )
