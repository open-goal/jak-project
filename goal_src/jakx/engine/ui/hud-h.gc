;; +++hud-sprite-flags
(defenum hud-sprite-flags
  :type uint16
  :bitfield #t
  (hsf0 0)
  (hsf1 1)
  (hsf2 2)
  (hsf3 3)
  (hsf4 4)
  (hsf5 5)
  (hsf6 6)
  (hsf7 7)
  (hsf8 8)
  (hsf9 9)
  (hsf10 10)
  (hsf11 11)
  (hsf12 12)
  (hsf13 13)
  (hsf14 14)
  (hsf15 15)
  )
;; ---hud-sprite-flags

