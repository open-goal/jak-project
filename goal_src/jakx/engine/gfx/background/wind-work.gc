;;-*-Lisp-*-
(in-package goal)

;; name: wind-work.gc
;; name in dgo: wind-work
;; dgos: ENGINE, GAME

;; DECOMP BEGINS

(define *wind-work* (new 'static 'wind-work
                      :wind-const (new 'static 'vector :data (new 'static 'array float 4 0.5 100.0 0.0166 -1.0))
                      )
        )

(set! (-> *wind-work* to-ptrs 0) (the-as uint (+ 8192 #x70000000)))

(set! (-> *wind-work* to-ptrs 1) (the-as uint (+ 4096 #x70000000)))

(set! (-> *wind-work* to-ptrs 2) (the-as uint (+ #x70000000 0)))
