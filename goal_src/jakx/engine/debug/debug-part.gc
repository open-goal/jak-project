(defun sparticle-track-root-money ((arg0 sparticle-system) (arg1 sparticle-cpuinfo) (arg2 vector))
  (let ((v1-2 (-> arg1 key 0 proc)))
    (when (!= (-> v1-2 type) hud-money)
      (let ((v1-4 (-> v1-2 root trans)))
        (set! (-> arg2 x) (-> v1-4 x))
        (set! (-> arg2 y) (+ 2048.0 (-> v1-4 y)))
        (set! (-> arg2 z) (-> v1-4 z))
        )
      )
    )
  0
  (none)
  )

