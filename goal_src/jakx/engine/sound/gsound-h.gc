;; +++sound-bank-mode
(defenum sound-bank-mode
  :type uint32
  (none 0)
  (unknown 1)
  (common 2)
  (mode 3)
  (full 4)
  (half 5)
  (halfa 6)
  (halfb 7)
  (halfc 8)
  (virtual 9)
  )
