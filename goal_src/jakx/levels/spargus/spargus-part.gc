;; WARN: Return type mismatch float vs none.
(defun spt-birth-func-brightness-spargus-sewer-water ((arg0 sparticle-system) (arg1 sparticle-cpuinfo) (arg2 sparticle-launchinfo))
  (let ((s5-0 (+ (mod (the-as int (rand-uint31-gen *random-generator*)) 41) 60))
        (s3-0 (mod (the-as int (rand-uint31-gen *random-generator*)) 21))
        (s4-0 (mod (the-as int (rand-uint31-gen *random-generator*)) 21))
        (v1-6 (+ (mod (the-as int (rand-uint31-gen *random-generator*)) 11) 40))
        )
    (set! (-> arg2 rotate-x) (the float (- s5-0 s3-0)))
    (set! (-> arg2 rotate-y) (the float (- s5-0 s4-0)))
    (set! (-> arg2 rotate-z) (the float (- s5-0 v1-6)))
    )
  (none)
  )

