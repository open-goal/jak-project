(in-package goal)

;; name: rustyh-part.gc
;; name in dgo: rustyh-part
;; dgos: RTH, RUSTYH

;; DECOMP BEGINS

;; WARN: Return type mismatch float vs none.
(defun spt-birth-func-brightness-fishtank-bubbles ((arg0 sparticle-system) (arg1 sparticle-cpuinfo) (arg2 sparticle-launchinfo))
  (let ((s5-0 (+ (mod (the-as int (rand-uint31-gen *random-generator*)) 51) 150))
        (s3-0 (+ (mod (the-as int (rand-uint31-gen *random-generator*)) 41) 40))
        (s4-0 (+ (mod (the-as int (rand-uint31-gen *random-generator*)) 21) 10))
        (v1-7 (mod (the-as int (rand-uint31-gen *random-generator*)) 6))
        )
    (set! (-> arg2 rotate-x) (the float (- s5-0 s3-0)))
    (set! (-> arg2 rotate-y) (the float (- s5-0 s4-0)))
    (set! (-> arg2 rotate-z) (the float (- s5-0 v1-7)))
    )
  (none)
  )

